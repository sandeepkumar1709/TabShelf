{
  "manifest_version": 3,
  "name": "TabCache",
  "description": "Save & restore tab sessions, with Gemini-powered auto-naming and smart grouping.",
  "version": "0.2.0",
  "action": {
    "default_title": "TabCache",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "storage", "favicon"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"]
}
